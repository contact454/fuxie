generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== ENUMS =====

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum Skill {
  HOEREN
  LESEN
  SCHREIBEN
  SPRECHEN
  GRAMMATIK
  WORTSCHATZ
}

enum ExamType {
  GOETHE
  TELC
  OESD
}

enum ExerciseType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  MATCHING
  FILL_IN_BLANK
  SPRACHBAUSTEINE
  WRITE_EMAIL
  WRITE_ESSAY
  FILL_FORM
  SUMMARY
  PRESENTATION
  ROLE_PLAY
  PLANNING
  DISCUSSION
  MEDIATION
  TEXT_RECONSTRUCTION
  DICTATION
  PRONUNCIATION
  FLASHCARD
  SENTENCE_ORDER
  WORD_FORMATION
}

enum WordType {
  NOMEN
  VERB
  ADJEKTIV
  ADVERB
  PRAEPOSITION
  KONJUNKTION
  PRONOMEN
  ARTIKEL
  PARTIKEL
  NUMERALE
  PHRASE
}

enum Gender {
  MASKULIN
  FEMININ
  NEUTRUM
}

enum SrsRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  LEARNER
  ADMIN
  CONTENT_CREATOR
}

// ===== AUTH & USERS =====

model User {
  id            String    @id @default(uuid())
  firebaseUid   String    @unique
  email         String    @unique
  role          UserRole  @default(LEARNER)
  emailVerified Boolean   @default(false)

  profile         UserProfile?
  settings        UserSettings?
  learningPath    LearningPath?
  srsCards        SrsCard[]
  srsReviewLogs   SrsReviewLog[]
  progress        UserProgress[]
  assessments     SkillAssessment[]
  examAttempts    ExamAttempt[]
  aiConversations AiConversation[]
  achievements    UserAchievement[]
  streak          UserStreak?
  dailyActivities    DailyActivity[]
  listeningAttempts  ListeningAttempt[]
  readingAttempts     ReadingAttempt[]
  writingAttempts     WritingAttempt[]
  vocabExerciseAttempts VocabExerciseAttempt[]
  grammarProgress       GrammarProgress[]
  speakingProgress      SpeakingProgress[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  displayName     String?
  avatarUrl       String?
  nativeLanguage  String    @default("vi")
  currentLevel    CefrLevel @default(A1)
  targetLevel     CefrLevel?
  targetExam      ExamType?
  targetExamDate  DateTime?
  studyGoalMinutes Int      @default(15)
  timezone        String    @default("Asia/Ho_Chi_Minh")

  totalXp               Int @default(0)
  totalWordsLearned     Int @default(0)
  totalLessonsCompleted Int @default(0)
  totalStudyMinutes     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  darkMode             Boolean @default(false)
  soundEnabled         Boolean @default(true)
  notificationsEnabled Boolean @default(true)
  srsNewCardsPerDay    Int     @default(20)
  srsReviewsPerDay     Int     @default(100)
  autoPlayAudio        Boolean @default(true)
  showTranslation      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

model LearningPath {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  currentCefrLevel CefrLevel @default(A1)
  targetCefrLevel  CefrLevel @default(B1)
  targetExamType   ExamType?
  startDate        DateTime  @default(now())
  targetDate       DateTime?
  weakSkills       Skill[]
  strongSkills     Skill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("learning_paths")
}

// ===== LEARNING CONTENT =====

model Course {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  titleDe     String?
  description String?
  cefrLevel   CefrLevel
  skill       Skill?
  examTypes   ExamType[]
  imageUrl    String?
  sortOrder   Int           @default(0)
  status      ContentStatus @default(DRAFT)

  modules Module[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cefrLevel])
  @@index([status])
  @@map("courses")
}

model Module {
  id               String        @id @default(uuid())
  courseId          String
  course           Course        @relation(fields: [courseId], references: [id])
  slug             String
  title            String
  titleDe          String?
  description      String?
  cefrLevel        CefrLevel
  skill            Skill?
  sortOrder        Int           @default(0)
  status           ContentStatus @default(DRAFT)
  estimatedMinutes Int           @default(30)

  lessons Lesson[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([courseId, slug])
  @@index([cefrLevel])
  @@map("modules")
}

model Lesson {
  id               String        @id @default(uuid())
  moduleId         String
  module           Module        @relation(fields: [moduleId], references: [id])
  slug             String
  title            String
  titleDe          String?
  description      String?
  cefrLevel        CefrLevel
  skill            Skill
  examTypes        ExamType[]
  sortOrder        Int           @default(0)
  status           ContentStatus @default(DRAFT)
  estimatedMinutes Int           @default(10)
  xpReward         Int           @default(20)

  contentJson Json?
  audioUrl    String?
  transcript  String?

  exercises Exercise[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([moduleId, slug])
  @@index([cefrLevel, skill])
  @@map("lessons")
}

model Exercise {
  id       String  @id @default(uuid())
  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id])

  cefrLevel    CefrLevel
  skill        Skill
  exerciseType ExerciseType
  examTypes    ExamType[]

  instruction   String
  instructionDe String?
  contentJson   Json
  audioUrl      String?
  imageUrl      String?

  maxScore         Int           @default(1)
  estimatedSeconds Int           @default(60)
  xpReward         Int           @default(10)

  explanation   String?
  explanationDe String?
  hint          String?
  hintDe        String?

  sortOrder  Int           @default(0)
  status     ContentStatus @default(DRAFT)
  difficulty Int           @default(1)

  grammarTopicId String?
  grammarTopic   GrammarTopic? @relation(fields: [grammarTopicId], references: [id])

  vocabularyItems VocabularyItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cefrLevel, skill, exerciseType])
  @@index([lessonId])
  @@map("exercises")
}

// ===== VOCABULARY =====

model VocabularyTheme {
  id        String    @id @default(uuid())
  slug      String    @unique
  name      String
  nameVi    String?
  nameEn    String?
  cefrLevel CefrLevel
  imageUrl  String?
  sortOrder Int       @default(0)

  items VocabularyItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cefrLevel])
  @@map("vocabulary_themes")
}

model VocabularyItem {
  id        String           @id @default(uuid())
  themeId   String?
  theme     VocabularyTheme? @relation(fields: [themeId], references: [id])

  word      String
  wordLower String
  article   Gender?
  plural    String?
  wordType  WordType
  cefrLevel CefrLevel

  meaningVi String
  meaningEn String?

  ipa      String?
  audioUrl String?

  exampleSentence1    String?
  exampleTranslation1 String?
  exampleSentence2    String?
  exampleTranslation2 String?

  notes       String?
  conjugation Json?
  imageUrl    String?

  exercises Exercise[]
  srsCards  SrsCard[]

  status    ContentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@unique([word, cefrLevel])
  @@index([cefrLevel, wordType])
  @@index([cefrLevel, themeId])
  @@index([wordLower])
  @@map("vocabulary_items")
}

// ===== GRAMMAR =====

model GrammarTopic {
  id            String        @id @default(uuid())
  slug          String        @unique
  title         String
  titleDe       String?
  titleVi       String?
  description   String?
  cefrLevel     CefrLevel
  sortOrder     Int           @default(0)
  status        ContentStatus @default(DRAFT)

  explanation   String?
  explanationDe String?
  formula       String?
  mnemonicTip   String?

  rules     GrammarRule[]
  lessons   GrammarLesson[]
  exercises Exercise[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cefrLevel])
  @@map("grammar_topics")
}

model GrammarRule {
  id         String       @id @default(uuid())
  topicId    String
  topic      GrammarTopic @relation(fields: [topicId], references: [id])

  title      String
  titleDe    String?
  ruleText   String
  ruleTextDe String?
  examples   Json
  exceptions Json?
  tableData  Json?
  sortOrder  Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("grammar_rules")
}

model GrammarLesson {
  id             String        @id              // "a1-praesens-01-E"
  topicId        String
  topic          GrammarTopic  @relation(fields: [topicId], references: [id])
  level          CefrLevel
  lessonType     String                         // "E" | "V" | "A"
  lessonNumber   Int
  titleDe        String
  titleVi        String
  estimatedMin   Int           @default(8)
  tags           String[]
  theoryJson     Json?                          // theory blocks (null for A-lessons)
  exercisesJson  Json                           // exercises array
  metadataJson   Json?
  sortOrder      Int           @default(0)
  status         ContentStatus @default(PUBLISHED)

  progress       GrammarProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([topicId, sortOrder])
  @@index([level])
  @@map("grammar_lessons")
}

model GrammarProgress {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  lessonId  String
  lesson    GrammarLesson @relation(fields: [lessonId], references: [id])

  score     Int?
  maxScore  Int?
  stars     Int?                               // 1-3
  completed Boolean       @default(false)
  attempts  Int           @default(0)
  lastAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("grammar_progress")
}

// ===== SRS =====

model SrsCard {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  vocabularyItemId String?
  vocabularyItem   VocabularyItem? @relation(fields: [vocabularyItemId], references: [id])
  grammarTopicId   String?

  interval       Float    @default(0)
  repetitions    Int      @default(0)
  easeFactor     Float    @default(2.5)
  nextReviewAt   DateTime @default(now())
  lastReviewedAt DateTime?

  stability     Float?
  difficulty    Float?
  elapsedDays   Float?
  scheduledDays Float?
  state         Int      @default(0)

  totalReviews   Int @default(0)
  totalCorrect   Int @default(0)
  totalIncorrect Int @default(0)
  lapseCount     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewLogs SrsReviewLog[]

  @@unique([userId, vocabularyItemId])
  @@index([userId, nextReviewAt])
  @@index([userId, state])
  @@map("srs_cards")
}

model SrsReviewLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  cardId String
  card   SrsCard @relation(fields: [cardId], references: [id])

  rating         SrsRating
  responseTimeMs Int?

  prevInterval   Float
  prevEaseFactor Float
  prevState      Int
  newInterval    Float
  newEaseFactor  Float
  newState       Int

  reviewedAt DateTime @default(now())

  @@index([userId, reviewedAt])
  @@index([cardId])
  @@map("srs_review_logs")
}

// ===== EXAMS =====

model ExamTemplate {
  id           String        @id @default(uuid())
  slug         String        @unique
  title        String
  examType     ExamType
  cefrLevel    CefrLevel
  totalMinutes Int
  totalPoints  Int
  passingScore Int
  description  String?
  status       ContentStatus @default(DRAFT)

  sections ExamSection[]
  attempts ExamAttempt[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([examType, cefrLevel])
  @@map("exam_templates")
}

model ExamSection {
  id           String       @id @default(uuid())
  examId       String
  exam         ExamTemplate @relation(fields: [examId], references: [id])

  title        String
  skill        Skill
  totalMinutes Int
  totalPoints  Int
  sortOrder    Int          @default(0)
  instructions String?

  tasks ExamTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exam_sections")
}

model ExamTask {
  id          String       @id @default(uuid())
  sectionId   String
  section     ExamSection  @relation(fields: [sectionId], references: [id])

  title       String
  exerciseType ExerciseType
  contentJson Json
  audioUrl    String?
  imageUrl    String?
  maxPoints   Int
  sortOrder   Int          @default(0)
  rubricJson  Json?

  answers ExamAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exam_tasks")
}

model ExamAttempt {
  id     String       @id @default(uuid())
  userId String
  user   User         @relation(fields: [userId], references: [id])
  examId String
  exam   ExamTemplate @relation(fields: [examId], references: [id])

  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  totalScore   Int?
  maxScore     Int?
  passed       Boolean?
  percentScore Float?

  scoreBreakdown Json?
  aiFeedback     String?
  feedbackJson   Json?

  answers ExamAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, examId])
  @@index([userId, completedAt])
  @@map("exam_attempts")
}

model ExamAnswer {
  id        String      @id @default(uuid())
  attemptId String
  attempt   ExamAttempt @relation(fields: [attemptId], references: [id])
  taskId    String
  task      ExamTask    @relation(fields: [taskId], references: [id])

  answerJson   Json
  score        Int?
  maxScore     Int?
  isCorrect    Boolean?
  aiFeedback   String?
  rubricScores Json?

  answeredAt DateTime @default(now())

  @@index([attemptId])
  @@map("exam_answers")
}

// ===== AI =====

model AiConversation {
  id     String    @id @default(uuid())
  userId String
  user   User      @relation(fields: [userId], references: [id])

  title           String?
  cefrLevel       CefrLevel
  context         String?
  totalMessages   Int       @default(0)
  totalTokensUsed Int       @default(0)

  messages AiMessage[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id])

  role       String
  content    String
  contentDe  String?
  audioUrl   String?
  model      String?
  tokensUsed Int?
  latencyMs  Int?
  corrections Json?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

// ===== GAMIFICATION =====

model Achievement {
  id             String @id @default(uuid())
  slug           String @unique
  title          String
  titleDe        String?
  description    String
  descriptionDe  String?
  iconUrl        String?
  category       String
  conditionType  String
  conditionValue Int
  xpReward       Int    @default(0)

  userAchievements UserAchievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  earnedAt DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserStreak {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])

  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  freezesAvailable Int       @default(1)
  freezesUsed      Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_streaks")
}

// ===== PROGRESS =====

model UserProgress {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  lessonId   String?
  exerciseId String?

  score            Int?
  maxScore         Int?
  percentScore     Float?
  xpEarned         Int    @default(0)
  timeSpentSeconds Int?

  completedAt DateTime @default(now())

  @@index([userId, completedAt])
  @@index([userId, lessonId])
  @@map("user_progress")
}

model SkillAssessment {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  skill          Skill
  cefrLevel      CefrLevel
  score          Float
  assessedAt     DateTime  @default(now())
  strengths      String[]
  weaknesses     String[]
  recommendation String?

  @@index([userId, skill])
  @@index([userId, assessedAt])
  @@map("skill_assessments")
}

model DailyActivity {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  date               DateTime @db.Date
  totalMinutes       Int      @default(0)
  xpEarned           Int      @default(0)
  lessonsCompleted   Int      @default(0)
  exercisesCompleted Int      @default(0)
  srsReviewed        Int      @default(0)
  wordsLearned       Int      @default(0)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_activities")
}

// ===== LISTENING =====

model ListeningLesson {
  id              String    @id @default(uuid())
  lessonId        String    @unique              // "L-A1-GOETHE-001-T1"
  cefrLevel       CefrLevel
  board           String    @default("GOETHE")   // GOETHE, TELC, OESD
  teil            Int                             // 1-4
  teilName        String                         // "Kurze Alltagsgespräche"
  title           String                         // Full German title
  topic           String                         // "Sich vorstellen und begrüßen"
  taskType        String                         // "MC a/b/c", "Richtig/Falsch"
  audioUrl        String                         // GCS URL to MP3
  audioDuration   Int?                           // in seconds
  backgroundScene String?                        // "cafe", "station"
  sortOrder       Int       @default(0)
  transcript      Json?                          // full script JSON for transcript display

  questions       ListeningQuestion[]
  attempts        ListeningAttempt[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cefrLevel, teil])
  @@index([cefrLevel, sortOrder])
  @@map("listening_lessons")
}

model ListeningQuestion {
  id              String          @id @default(uuid())
  lessonId        String
  lesson          ListeningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questionNumber  Int                             // 1-15
  questionType    String                          // "mc_abc", "richtig_falsch", "zuordnung", "ja_nein"
  questionText    String                          // German question
  questionTextVi  String?                         // Vietnamese translation
  options         Json                            // ["a) ...", "b) ...", "c) ..."]
  correctAnswer   String                          // "b"
  explanation     String?                         // Why this answer is correct
  explanationVi   String?                         // Vietnamese explanation
  timestampStart  Float?                          // Audio timestamp where answer appears
  timestampEnd    Float?
  sortOrder       Int             @default(0)

  responses       ListeningResponse[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([lessonId, questionNumber])
  @@index([lessonId])
  @@map("listening_questions")
}

model ListeningAttempt {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  lessonId        String
  lesson          ListeningLesson @relation(fields: [lessonId], references: [id])
  score           Int                             // Correct answers count
  totalQuestions  Int
  percentage      Float
  timeTaken       Int?                            // seconds
  listenCount     Int             @default(1)     // How many times audio played

  responses       ListeningResponse[]

  completedAt     DateTime        @default(now())

  @@index([userId, lessonId])
  @@index([userId, completedAt])
  @@map("listening_attempts")
}

model ListeningResponse {
  id              String            @id @default(uuid())
  attemptId       String
  attempt         ListeningAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String
  question        ListeningQuestion @relation(fields: [questionId], references: [id])
  userAnswer      String
  isCorrect       Boolean

  createdAt       DateTime          @default(now())

  @@index([attemptId])
  @@map("listening_responses")
}

// ===== READING =====

model ReadingExercise {
  id            String    @id @default(uuid())
  exerciseId    String    @unique              // "A1-T1-001"
  cefrLevel     CefrLevel
  teil          Int                             // 1-5
  teilName      String                          // "Kurze Texte lesen"
  topic         String                          // "Im Supermarkt"
  textsJson     Json                            // Array of text objects (emails, blogs, articles)
  imagesJson    Json?                           // Array of image refs [{id, type, filename, alt_text}]
  scoringJson   Json?                           // Grading scale with ranges and labels
  metadataJson  Json?                           // word count, grammar, vocabulary targets
  sortOrder     Int       @default(0)

  questions     ReadingQuestion[]
  attempts      ReadingAttempt[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([cefrLevel, teil])
  @@index([cefrLevel, sortOrder])
  @@map("reading_exercises")
}

model ReadingQuestion {
  id              String           @id @default(uuid())
  exerciseId      String
  exercise        ReadingExercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  questionNumber  Int                              // 1-10
  questionType    String                           // "richtig_falsch", "mc_abc", "matching_ab", "lueckentext", "ja_nein"
  linkedText      String?                          // "TextA", "TextB" — which text this question refers to
  statement       String                           // German question/statement
  options         Json?                            // For MC: ["a) ...", "b) ...", "c) ..."]
  correctAnswer   String                           // "richtig", "falsch", "a", "b", etc.
  points          Int              @default(1)
  explanation     Json?                            // {de, key_evidence, key_vocabulary[]}
  sortOrder       Int              @default(0)

  responses       ReadingResponse[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([exerciseId, questionNumber])
  @@index([exerciseId])
  @@map("reading_questions")
}

model ReadingAttempt {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  exerciseId      String
  exercise        ReadingExercise  @relation(fields: [exerciseId], references: [id])
  score           Int                              // Correct answers count
  totalQuestions  Int
  percentage      Float
  timeTaken       Int?                             // seconds

  responses       ReadingResponse[]

  completedAt     DateTime         @default(now())

  @@index([userId, exerciseId])
  @@index([userId, completedAt])
  @@map("reading_attempts")
}

model ReadingResponse {
  id              String           @id @default(uuid())
  attemptId       String
  attempt         ReadingAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String
  question        ReadingQuestion  @relation(fields: [questionId], references: [id])
  userAnswer      String
  isCorrect       Boolean

  createdAt       DateTime         @default(now())

  @@index([attemptId])
  @@map("reading_responses")
}

// ===== VOCAB EXERCISES =====

model VocabExerciseAttempt {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])

  exerciseType String                // "mc", "matching", "spelling", "cloze", "scramble", "speed"
  themeSlug    String
  cefrLevel    CefrLevel

  totalQuestions Int
  correctCount   Int
  score          Int                  // XP earned
  timeTaken      Int?                 // seconds
  accuracy       Float                // 0-100

  details    Json?                    // { questions, answers }

  createdAt DateTime @default(now())

  @@index([userId, exerciseType])
  @@index([userId, cefrLevel])
  @@index([userId, createdAt])
  @@map("vocab_exercise_attempts")
}

// ===== WRITING =====

model WritingExercise {
  id            String        @id @default(uuid())
  exerciseId    String        @unique              // "W-A1-T1-001"
  cefrLevel     CefrLevel
  teil          Int                                // 1-3
  teilName      String                             // "Formular ausfüllen"
  textType      String                             // "Formular", "E-Mail", "Forumsbeitrag", etc.
  register      String                             // "formell", "informell", "neutral"
  topic         String                             // "Deutschkurs"

  // Task definition
  instruction    String                            // Aufgabenstellung (German)
  instructionVi  String?                           // Vietnamese translation
  situation      String                            // Kontext/Situation
  contentPoints  Json                              // ["Sich vorstellen", "Interesse zeigen", ...]
  sampleResponse String?                           // Musterlösung

  // Form fields (for Formular type)
  formFields     Json?                             // [{label, type, placeholder}]

  // Source text (for Textumwandlung type)
  sourceText     String?                           // Ausgangstext
  sourceTextType String?                           // "Blogpost", "Vortrag", etc.

  // Grafik (for C1 Argumentation type)
  grafikUrl      String?                           // URL to chart/graph image
  grafikDesc     String?                           // Description of the chart

  // Constraints
  minWords       Int
  maxWords       Int?
  timeMinutes    Int           @default(15)        // Suggested time

  // Rubric & Scoring
  rubricJson     Json                              // Level-specific rubric with criteria + weights
  maxScore       Int           @default(25)        // Max achievable score

  // Metadata
  imageUrl       String?
  sortOrder      Int           @default(0)
  status         ContentStatus @default(DRAFT)

  attempts       WritingAttempt[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([cefrLevel, teil])
  @@index([cefrLevel, sortOrder])
  @@map("writing_exercises")
}

model WritingAttempt {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  exerciseId      String
  exercise        WritingExercise  @relation(fields: [exerciseId], references: [id])

  // Student submission
  submittedText   String                           // Full text submitted
  wordCount       Int                              // Actual word count

  // AI Scores (0-5 each criterion)
  scoreInhalt          Int?                        // Content fulfillment
  scoreAngemessenheit  Int?                        // Communicative appropriateness
  scoreKorrektheit     Int?                        // Grammar/spelling accuracy
  scoreSpektrum        Int?                        // Vocabulary/structure range
  scoreKohaerenz       Int?                        // Coherence & cohesion
  totalScore           Int?                        // Sum of above
  maxScore             Int?                        // Max possible
  percentScore         Float?                      // Percentage

  // AI Feedback
  feedbackOverall  String?                         // Overall AI feedback text
  feedbackJson     Json?                           // Per-criterion: {criterion, score, reasoning, suggestions[]}
  correctionsJson  Json?                           // Inline corrections: [{original, corrected, type, explanation}]
  estimatedLevel   CefrLevel?                      // AI-estimated CEFR level of this text

  // Timing
  timeSpentSeconds Int?                            // Time spent writing

  submittedAt      DateTime     @default(now())

  @@index([userId, exerciseId])
  @@index([userId, submittedAt])
  @@map("writing_attempts")
}

// ===== SPEAKING =====

model SpeakingTopic {
  id          String        @id @default(uuid())
  slug        String        @unique          // "a1-begruessung"
  titleDe     String
  titleVi     String
  description String?
  cefrLevel   CefrLevel
  sortOrder   Int           @default(0)
  status      ContentStatus @default(DRAFT)

  lessons     SpeakingLesson[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([cefrLevel])
  @@map("speaking_topics")
}

model SpeakingLesson {
  id             String         @id              // "a1-begruessung-01-nachsprechen"
  topicId        String
  topic          SpeakingTopic  @relation(fields: [topicId], references: [id])
  level          CefrLevel
  lessonType     String                          // "E" | "V" | "A"
  lessonNumber   Int
  titleDe        String
  titleVi        String
  exerciseType   String                          // "nachsprechen" | "wort_lesen" | etc.
  exercisesJson  Json                            // array of exercise items
  configJson     Json?                           // { maxRecordingSec, minAccuracy, attemptsAllowed, ... }
  estimatedMin   Int            @default(5)
  sortOrder      Int            @default(0)
  status         ContentStatus  @default(PUBLISHED)

  progress       SpeakingProgress[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([topicId, sortOrder])
  @@index([level])
  @@map("speaking_lessons")
}

model SpeakingProgress {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  lessonId  String
  lesson    SpeakingLesson @relation(fields: [lessonId], references: [id])

  score     Int?                               // overall accuracy score 0-100
  maxScore  Int?                               // max possible (usually 100)
  stars     Int?                               // 1-3 stars
  completed Boolean        @default(false)
  attempts  Int            @default(0)
  lastAt    DateTime?

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("speaking_progress")
}
